# Copy this file to ".env" and fill in your real values, then deploy.
#   cp .env.example .env
#
# These feed the backend so the contact form can email enquiries.

# MochaHost SMTP (confirm host in cPanel -> Email Accounts -> Connect Devices)
SMTP_HOST=mail.vinayanainfra.com
SMTP_PORT=587
SMTP_USER=info@vinayanainfra.com
SMTP_PASS=your-mailbox-password-here
MAIL_FROM=info@vinayanainfra.com
MAIL_TO=info@vinayanainfra.com
